          "type": "string",
        },
        "values": {
          "description": "Values to search for in sampled warehouse dictionaries.",
          "items": {
            "description": "Business value to locate, e.g. "Acme Corp" or "enterprise".",
            "minLength": 1,
            "type": "string",
          },
          "maxItems": 20,
          "minItems": 1,
          "type": "array",
        },
      },
